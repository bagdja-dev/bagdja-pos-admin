## ─── Public (client-side) ───────────────────────────────
# Endpoint API backend (bagdja-pos-api)
NEXT_PUBLIC_API_URL=http://localhost:5006

# SSO Bagdja — bagdja-login (browser-facing BFF di port 4002: UI
# login/authorize + /logout; bagdja-auth di port 4001 dipanggil dari sisi
# server oleh bagdja-login sendiri, browser tidak pernah langsung ke situ)
NEXT_PUBLIC_AUTH_URL=http://localhost:4002

# Client ID OAuth khusus untuk admin (BEDA dari CLIENT_APP_ID milik api/,
# yang itu untuk service-to-service. Ini untuk end-user login PKCE flow.
# Wajib didaftarkan di bagdja-console sebagai OAuth client baru.
NEXT_PUBLIC_CLIENT_ID=bagdja-pos-admin

# URL aplikasi admin ini (untuk redirect setelah logout SSO)
NEXT_PUBLIC_APP_URL=http://localhost:5007

# Redirect setelah callback OAuth — wajib cocok dengan yang didaftarkan di bagdja-auth
NEXT_PUBLIC_REDIRECT_URI=http://localhost:5007/auth/callback

## ─── Server-side (jangan expose ke client) ──────────────
# Secret untuk exchange authorization code → access token
OAUTH_CLIENT_SECRET=change-me
